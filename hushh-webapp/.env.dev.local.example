# Frontend local profile: development
# Copy to hushh-webapp/.env.dev.local and set real local values.

# ---------------------------------------------------------------------------
# Canonical environment identity
# ---------------------------------------------------------------------------
NEXT_PUBLIC_APP_ENV=development

# ---------------------------------------------------------------------------
# Backend
# ---------------------------------------------------------------------------
NEXT_PUBLIC_BACKEND_URL=http://localhost:8000
NEXT_PUBLIC_APP_URL=http://localhost:3000
NEXT_PUBLIC_FRONTEND_URL=http://localhost:3000

# ---------------------------------------------------------------------------
# Firebase (base app)
# ---------------------------------------------------------------------------
NEXT_PUBLIC_FIREBASE_API_KEY=replace_with_dev_firebase_api_key
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=replace_with_dev_auth_domain
NEXT_PUBLIC_FIREBASE_PROJECT_ID=replace_with_dev_project_id
NEXT_PUBLIC_FIREBASE_STORAGE_BUCKET=replace_with_dev_storage_bucket
NEXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=replace_with_dev_sender_id
NEXT_PUBLIC_FIREBASE_APP_ID=replace_with_dev_app_id
NEXT_PUBLIC_FIREBASE_VAPID_KEY=replace_with_dev_vapid_key

# ---------------------------------------------------------------------------
# Firebase auth split (optional)
# ---------------------------------------------------------------------------
NEXT_PUBLIC_AUTH_FIREBASE_API_KEY=
NEXT_PUBLIC_AUTH_FIREBASE_AUTH_DOMAIN=
NEXT_PUBLIC_AUTH_FIREBASE_PROJECT_ID=
NEXT_PUBLIC_AUTH_FIREBASE_APP_ID=

# ---------------------------------------------------------------------------
# Server-only Firebase Admin (for Next.js API route token verification)
# ---------------------------------------------------------------------------
FIREBASE_SERVICE_ACCOUNT_JSON=
FIREBASE_AUTH_SERVICE_ACCOUNT_JSON=

# ---------------------------------------------------------------------------
# Observability
# ---------------------------------------------------------------------------
NEXT_PUBLIC_OBSERVABILITY_ENABLED=true
NEXT_PUBLIC_OBSERVABILITY_DEBUG=false
NEXT_PUBLIC_OBSERVABILITY_SAMPLE_RATE=1
NEXT_PUBLIC_FIREBASE_MEASUREMENT_ID_STAGING=
NEXT_PUBLIC_FIREBASE_MEASUREMENT_ID_PRODUCTION=
NEXT_PUBLIC_GTM_ID_STAGING=
NEXT_PUBLIC_GTM_ID_PRODUCTION=
