# Frontend runtime profile: local-uatdb
# Local frontend + local backend, while Firebase/app resources stay on UAT.

APP_RUNTIME_PROFILE=local-uatdb
NEXT_PUBLIC_APP_ENV=development
NEXT_PUBLIC_BACKEND_URL=http://localhost:8000
NEXT_PUBLIC_APP_URL=http://localhost:3000
NEXT_PUBLIC_FRONTEND_URL=http://localhost:3000

NEXT_PUBLIC_FIREBASE_API_KEY=replace_with_uat_firebase_api_key
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=replace_with_uat_auth_domain
NEXT_PUBLIC_FIREBASE_PROJECT_ID=replace_with_uat_project_id
NEXT_PUBLIC_FIREBASE_STORAGE_BUCKET=replace_with_uat_storage_bucket
NEXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=replace_with_uat_sender_id
NEXT_PUBLIC_FIREBASE_APP_ID=replace_with_uat_app_id
NEXT_PUBLIC_FIREBASE_VAPID_KEY=replace_with_uat_vapid_key

NEXT_PUBLIC_AUTH_FIREBASE_API_KEY=replace_with_auth_project_api_key
NEXT_PUBLIC_AUTH_FIREBASE_AUTH_DOMAIN=replace_with_auth_project_auth_domain
NEXT_PUBLIC_AUTH_FIREBASE_PROJECT_ID=replace_with_auth_project_id
NEXT_PUBLIC_AUTH_FIREBASE_APP_ID=replace_with_auth_project_app_id

FIREBASE_SERVICE_ACCOUNT_JSON=replace_with_uat_service_account_json
FIREBASE_AUTH_SERVICE_ACCOUNT_JSON=replace_with_auth_project_service_account_json

NEXT_PUBLIC_OBSERVABILITY_ENABLED=true
NEXT_PUBLIC_OBSERVABILITY_DEBUG=false
NEXT_PUBLIC_OBSERVABILITY_SAMPLE_RATE=1
NEXT_PUBLIC_FIREBASE_MEASUREMENT_ID_UAT=replace_with_uat_measurement_id
NEXT_PUBLIC_FIREBASE_MEASUREMENT_ID_STAGING=replace_with_uat_measurement_id
NEXT_PUBLIC_FIREBASE_MEASUREMENT_ID_PRODUCTION=replace_with_prod_measurement_id_if_needed
NEXT_PUBLIC_GTM_ID_UAT=replace_with_uat_gtm_id
NEXT_PUBLIC_GTM_ID_STAGING=replace_with_uat_gtm_id
NEXT_PUBLIC_GTM_ID_PRODUCTION=replace_with_prod_gtm_id_if_needed
