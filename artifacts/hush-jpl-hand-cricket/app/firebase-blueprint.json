{
  "entities": {
    "User": {
      "title": "User Profile",
      "description": "User account and usage tracking",
      "type": "object",
      "properties": {
        "displayName": { "type": "string" },
        "team": { "type": "string", "enum": ["Chennai", "Bengaluru", "Delhi", "Kolkata", "Mumbai", "Hyderabad"] },
        "gamesPlayed24h": { "type": "integer" },
        "botGamesPlayed24h": { "type": "integer" },
        "lastResetTime": { "type": "string", "format": "date-time" },
        "lastClaimedReward": { "type": "string", "format": "date-time" },
        "xp": { "type": "integer" },
        "streak": { "type": "integer" },
        "totalWins": { "type": "integer" },
        "totalRuns": { "type": "integer" }
      },
      "required": ["displayName", "team"]
    },
    "Match": {
      "title": "Cricket Match",
      "description": "Real-time game state for a hand cricket match",
      "type": "object",
      "properties": {
        "status": { "type": "string", "enum": ["searching", "toss", "playing", "finished"] },
        "players": { "type": "object" },
        "isBotMatch": { "type": "boolean" },
        "currentBatterId": { "type": "string" },
        "currentBowlerId": { "type": "string" },
        "innings": { "type": "integer" },
        "scoreP1": { "type": "integer" },
        "scoreP2": { "type": "integer" },
        "target": { "type": "integer" },
        "lastMoves": { "type": "object" },
        "history": { "type": "array" },
        "winnerId": { "type": "string" },
        "tossWinnerId": { "type": "string" },
        "tossChoice": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" },
        "updatedAt": { "type": "string", "format": "date-time" }
      }
    },
    "DailyWinner": {
      "title": "Daily Champion",
      "description": "Records for leaderboard and rewards",
      "type": "object",
      "properties": {
        "userId": { "type": "string" },
        "displayName": { "type": "string" },
        "date": { "type": "string" },
        "reward": { "type": "string" },
        "score": { "type": "integer" }
      }
    }
  },
  "firestore": {
    "/users/{userId}": {
      "schema": "User",
      "description": "Individual user data and usage limits"
    },
    "/matches/{matchId}": {
      "schema": "Match",
      "description": "Active game sessions"
    },
    "/leaderboard/{date}/winners/{userId}": {
      "schema": "DailyWinner",
      "description": "Daily leaderboard and reward recipients"
    }
  }
}
