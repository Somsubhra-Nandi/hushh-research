{
  "id": "founder-brief-curation",
  "title": "Founder Brief Curation",
  "goal": "Draft and polish founder-facing architecture briefs, presentation-grade markdown/html/pdf artifacts, and shared technical papers that stay grounded in repo truth.",
  "owner_skill": "docs-governance",
  "default_spoke": "founder-brief-curation",
  "task_type": "founder-brief-curation",
  "affected_surfaces": [
    "docs",
    "consent-protocol/docs",
    "hushh-webapp/docs",
    "tmp"
  ],
  "required_reads": [
    ".codex/skills/founder-brief-curation/references/brief-curation-rules.md",
    ".codex/skills/docs-governance/references/founder-document-cadence.md",
    "docs/reference/operations/documentation-architecture-map.md"
  ],
  "required_commands": [
    "./bin/hushh codex route-task founder-brief-curation",
    "./bin/hushh docs verify",
    "python3 .codex/skills/docs-governance/scripts/doc_inventory.py tier-a"
  ],
  "verification_bundle": {
    "id": "founder-brief-curation",
    "commands": [
      "./bin/hushh docs verify",
      "python3 .codex/skills/docs-governance/scripts/doc_inventory.py tier-a"
    ],
    "tests": [
      "./bin/hushh docs verify"
    ]
