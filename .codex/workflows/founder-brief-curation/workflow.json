    "rendered shareable pdf when requested",
    "diagram verification note based on rendered output"
  ],
  "impact_fields": [
    "Artifact paths updated",
    "Rendered output verified",
    "Canonical references linked"
  ],
  "handoff_chain": [
    "docs-governance",
    "founder-brief-curation",
    "frontend",
    "backend",
    "iam-consent-governance",
    "mcp-developer-surface",
    "kai-voice-governance"
  ],
  "common_failures": [
    "opening with defensive caveats instead of the platform thesis",
    "leaving internal drafting provenance in a shared artifact",
    "allowing diagram text to overflow or crowd box edges",
    "using repo-relative references that are not clickable in the exported artifact",
    "overstating unbuilt architecture as current truth"
  ]
